<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="#1A237E"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="24dp">

                <ImageButton
                    android:id="@+id/backBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginEnd="12dp"
                    app:tint="#FFFFFF"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sales Invoice"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvBillId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#90CAF9"
                        android:textSize="13sp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#BBDEFB"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="48dp"
                android:visibility="gone"/>

            <!-- Main content -->
            <LinearLayout
                android:id="@+id/contentCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <!-- Customer card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Accent bar -->
                        <View
                            android:layout_width="5dp"
                            android:layout_height="match_parent"
                            android:background="#1A237E"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BILL TO"
                                android:textColor="#9E9E9E"
                                android:textSize="10sp"
                                android:letterSpacing="0.1"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:id="@+id/tvCustomerFirm"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#1A237E"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:id="@+id/tvCustomerName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#424242"
                                android:textSize="13sp"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvCustomerPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#757575"
                                android:textSize="12sp"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvCustomerAddr"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#757575"
                                android:textSize="12sp"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvGstin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#757575"
                                android:textSize="12sp"
                                android:visibility="gone"/>

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Items card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Items table header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#1A237E"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2.5"
                                android:text="Product"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Qty"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1.2"
                                android:text="Rate"
                                android:gravity="end"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1.2"
                                android:text="Amount"
                                android:gravity="end"
                                android:textColor="#C8E6C9"
                                android:textSize="11sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <!-- Items injected here -->
                        <LinearLayout
                            android:id="@+id/itemsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingHorizontal="16dp"/>

                        <!-- Subtotal -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="#F5F5F5"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Subtotal"
                                android:textColor="#757575"
                                android:textSize="12sp"/>

                            <TextView
                                android:id="@+id/tvSubtotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#424242"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <!-- Grand Total -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="#1A237E"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Grand Total"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvGrandTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#A5D6A7"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShare"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Share PDF"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1A237E"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_share"
                        app:iconSize="18dp"
                        app:iconTint="#FFFFFF"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrint"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Print"
                        android:textColor="#1A237E"
                        android:backgroundTint="#E8EAF6"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_print"
                        app:iconSize="18dp"
                        app:iconTint="#1A237E"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClose"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="Close"
                        android:textColor="#757575"
                        android:backgroundTint="#F5F5F5"
                        app:cornerRadius="12dp"/>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>