<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- PAGE TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Company Profile"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp"/>

        <!-- COMPANY INFORMATION -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Company Information"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/section_financial"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <!-- Company Name -->

            <TextView
                android:text="Company Name"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvCompanyName"
                android:text="Universal Trading Company"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_dark"
                android:layout_marginBottom="12dp"/>

            <!-- GSTIN -->

            <TextView
                android:text="GSTIN"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvGstin"
                android:text="29ABCDE1234F1Z5"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_dark"
                android:layout_marginBottom="12dp"/>

            <!-- Address -->

            <TextView
                android:text="Address"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvAddress"
                android:text="123 Business Street, Industrial Area, Bengaluru, Karnataka - 560001"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_dark"
                android:layout_marginBottom="12dp"/>

            <!-- Owner -->

            <TextView
                android:text="Owner Name"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvOwnerName"
                android:text="Owner"
                android:textColor="@color/text_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>


        <!-- ACCOUNT SETTINGS -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account Settings"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/section_financial"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <!-- Username -->

            <TextView
                android:text="Username"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvUsername"
                android:text="admin_user"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Password -->

            <TextView
                android:text="Password"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvPassword"
                android:text="********"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- RESET PASSWORD BUTTON -->

            <Button
                android:id="@+id/btnResetPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Reset Password"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_primary"/>

        </LinearLayout>


        <!-- LOGOUT BUTTON -->

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Logout"
            android:textColor="@color/button_text"
            android:textSize="16sp"
            android:backgroundTint="@color/payable_red"/>

    </LinearLayout>

</ScrollView>